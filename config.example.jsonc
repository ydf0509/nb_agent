{
  // LLM 提供商配置
  "provider": {
    "deepseek": {
      "name": "DeepSeek",
      "base_url": "https://api.deepseek.com/v1",
      "api_key": "{env:DEEPSEEK_API_KEY}",
      "models": {
        "deepseek-chat": {
          "name": "DeepSeek V3",
          "limit": { "context": 64000, "output": 8192 }
        },
        // raw_model: 当配置 key 与 API 实际模型名不一致时使用 raw_model 指定真实模型名
        // 若未设置 raw_model，则直接用 key 作为模型名请求接口
        "ds-deepseek-v4-flash-200k": {
          "name": "DeepSeek V4 Flash (官方直连)",
          "raw_model": "deepseek-chat",
          "limit": { "context": 200000, "output": 64000 }
        },
        "deepseek-reasoner": {
          "name": "DeepSeek R1",
          "limit": { "context": 64000, "output": 8192 }
        }
      }
    }
  },

  // Agent 行为
  "agent": {
    "system_prompt": "你是一个智能助手。",
    "default_model": "deepseek-chat",
    "streaming": true
  },

  // MCP Server 配置（可选），取消注释即可启用
  "mcp": {
    // 本地 stdio 方式启动自定义 MCP Server（FastMCP 编写）
    // "bookmark": {
    //   "type": "local",
    //   "command": ["python", "mcp_servers/bookmark_server.py"],
    //   "enabled": true
    // },
    // SSE 方式连接远程 MCP Server
    // "web-search": {
    //   "type": "sse",
    //   "url": "http://localhost:3000/sse",
    //   "enabled": true
    // },
    // HTTP 方式连接远程 MCP Server（streamableHttp 协议，http 是别名）
    // 先独立启动服务：uvx nbrag --transport streamable-http --port 9101
    // "nbrag": {
    //   "type": "http",
    //   "url": "http://localhost:9101/mcp"
    // },
    // 文件系统 MCP：让 AI 读写指定目录的文件
    // ⚠ 必须至少提供一个绝对路径，AI 只能访问列出的目录
    // "filesystem": {
    //   "type": "local",
    //   "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/path/to/your/project"]
    // },
    // Serena（语义级编程 MCP：代码索引、符号导航、跨文件重构、智能编辑）
    // 安装: uv tool install -p 3.12 serena-agent@latest --prerelease=allow
    // "serena": {
    //   "type": "local",
    //   "command": "serena",
    //   "args": ["start-mcp-server", "--project-from-cwd"],
    //   "enabled": false
    // },
    // context7（实时文档查询 MCP：查任意库的官方文档和代码示例）
    // "context7": {
    //   "type": "local",
    //   "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
    //   "enabled": false
    // }
  },

  // 审批规则
  "approval": {
    "dangerous_tools": [],
    "auto_approve": false
  },

  // 会话存储
  "session": {
    "db_path": ""  // 空 = 默认 ~/.nb_agent/sessions.db
  }
}
